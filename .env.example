# Standard PostgreSQL URL (required). Do NOT use prisma+postgres:// here.
#
# Supabase: Project Settings → Database → Connection string → URI
# Example:
# DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres"
#
# Local Prisma Postgres: run `npx prisma dev` in another terminal, then paste
# the postgresql:// URL from its output (not the prisma+postgres:// one).
# Pooled connection (Supabase: Transaction pooler, port 6543)
DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection for migrations (Supabase: Session pooler or Direct, port 5432)
DIRECT_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Single app user (set strong values in production)
APP_USERNAME="admin"
APP_PASSWORD="change-me-to-a-long-password"

# JWT signing secret (min 16 characters)
AUTH_SECRET="replace-with-a-random-secret-at-least-16-chars"
